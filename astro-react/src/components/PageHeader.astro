---
interface Props {
  title: string;
  breadcrumbs?: { label: string; href: string }[];
}

const { title, breadcrumbs } = Astro.props;

// Sostituisce le 'i' minuscole con una 'ı' (i senza puntino) e un puntino rosso posizionato in modo assoluto
const titleWithRedDots = title.replace(
  /i/g, 
  '<span class="relative inline-block"><span aria-hidden="true" class="opacity-0">i</span><span class="absolute inset-0 text-white">ı</span><span class="absolute inset-0 text-[#e30613] origin-bottom font-bold" style="clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);">i</span></span>'
);
---

<div class="w-full">
  {/* Classic Professional Corporate Header */}
  <section class="relative bg-gradient-to-r from-[#0b3c82] to-[#07224d] overflow-hidden">
    
    {/* Very subtle elegant texture to remove flatness */}
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.05) 10px, rgba(255,255,255,0.05) 11px);"></div>
    
    {/* Large watermark of the logo */}
    <div class="absolute -right-20 -top-40 w-96 h-96 border-[40px] border-white/5 rounded-full pointer-events-none"></div>
    <div class="absolute -right-10 -top-20 w-64 h-64 border-[20px] border-white/5 rounded-full pointer-events-none"></div>

    {/* Content */}
    <div class="container-custom relative z-10 pt-14 pb-12 md:pt-16 md:pb-14 text-center md:text-left">
      <div class="max-w-4xl">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white tracking-tight leading-tight" set:html={titleWithRedDots}>
        </h1>
      </div>
    </div>
  </section>

  {/* Clean Minimalist Breadcrumbs */}
  {breadcrumbs && breadcrumbs.length > 0 && (
    <div class="bg-gray-50 border-b border-gray-200 py-3 shadow-sm relative z-20">
      <div class="container-custom">
        <nav class="flex text-sm text-gray-500 font-sans" aria-label="Breadcrumb">
          <ol class="inline-flex items-center space-x-2 md:space-x-3">
            {breadcrumbs.map((crumb, index) => (
              <li class="inline-flex items-center">
                {index > 0 && (
                  <span class="text-gray-400 mx-2 select-none">/</span>
                )}
                {index === breadcrumbs.length - 1 ? (
                  <span class="text-gray-900 font-semibold tracking-wide">
                    {crumb.label}
                  </span>
                ) : (
                  <a href={crumb.href} class="inline-flex items-center hover:text-[#0b3c82] transition-colors font-medium">
                    {crumb.label}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      </div>
    </div>
  )}
</div>
