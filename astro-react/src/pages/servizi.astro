---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import PageHeader from '../components/PageHeader.astro';
import ServiziTabs from '../components/ServiziTabs';
---

<Layout title="Servizi">
  <Header client:load />

  <main>
    {/* Page Header Riutilizzabile */}
    <PageHeader 
      title="I Nostri Servizi" 
      breadcrumbs={[
        { label: 'Home', href: '/' },
        { label: 'Servizi', href: '/servizi' }
      ]} 
    />

    {/* Intro Section - Stessa struttura di Chi Siamo */}
    <section class="relative py-16 md:py-24 overflow-hidden bg-white">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-10 left-10 w-96 h-96 bg-[#0b3c82]/5 rounded-full blur-3xl"></div>
        
      </div>

      <div class="container-custom relative z-10">
        <div class="space-y-3 md:space-y-4 mb-16 text-center">
          <span class="inline-block text-xs font-semibold tracking-widest text-[#0b3c82] bg-blue-50 px-3.5 py-1.5 rounded-full uppercase font-sans">
            Aree di Intervento
          </span>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-gray-900 leading-tight">
            Sostegno, Cura e Riabilitazione
          </h2>
          <p class="text-base sm:text-lg text-gray-600 leading-relaxed font-sans max-w-2xl mx-auto">
            La Cooperativa Sociale Centro Felicemente svolge la propria attività a Cusago (MI). Offriamo una gamma completa di servizi dedicati sia all'età evolutiva che agli adulti.
          </p>
        </div>

        {/* Accordion Component */}
        <ServiziTabs client:load />
      </div>
    </section>

  </main>

  <Footer client:load />
</Layout>
