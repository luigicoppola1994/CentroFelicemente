---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner';
import ChatBot from '../components/ChatBot';
import { ViewTransitions } from 'astro:transitions';
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Centro Felicemente - Professionalità e passione al servizio di chi ha bisogno" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/faviconcentro.jpg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Centro Felicemente</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=SF+Pro+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ViewTransitions />
  </head>
  <body>
    <slot />
    <CookieBanner client:load transition:persist />
    <ChatBot client:load transition:persist />
  </body>
</html>
